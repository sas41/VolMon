<?xml version="1.0" encoding="UTF-8"?>
<!--
  VolMon WiX 4 installer source.

  Installs all four binaries + icon to %ProgramFiles%\VolMon\, then runs
  register.ps1 as the current user (via a deferred+impersonated ExeCommand
  custom action) to register Task Scheduler tasks and startup shortcuts.

  The installer presents two features:
    - VolMon (required) — daemon + GUI
    - Hardware Support (optional, default off) — hardware daemon + hardware GUI
      Includes the layout files and fonts under Hardware\Beacn\Mix\Layouts\.

  Build command (called from the CI workflow):
    wix build volmon.wxs \
      -ext WixToolset.UI.wixext \
      -d SourceDir=<path-to-publish/win-x64> \
      -d Version=<semver> \
      -arch x64 \
      -o VolMon-win-x64.msi
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package
    Name="VolMon"
    Manufacturer="VolMon"
    Version="$(Version)"
    UpgradeCode="4A8B2C1D-3E4F-5A6B-7C8D-9E0F1A2B3C4D"
    Scope="perMachine"
    InstallerVersion="500"
    Compressed="yes">

    <!-- Always overwrite older versions, remove before upgrading -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of VolMon is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <!-- Show the feature-selection dialog so the user can opt in to hardware support -->
    <ui:WixUI Id="WixUI_FeatureTree" />

    <!-- ── Directory tree ────────────────────────────────────────── -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="VolMon">
        <Directory Id="HardwareDir" Name="Hardware">
          <Directory Id="BeacnDir"  Name="Beacn">
            <Directory Id="MixDir"  Name="Mix">
              <Directory Id="LayoutsDir"        Name="Layouts">
                <Directory Id="LayoutsFontsDir" Name="Fonts" />
              </Directory>
            </Directory>
          </Directory>
        </Directory>
      </Directory>
    </StandardDirectory>

    <!-- ── Core files ────────────────────────────────────────────── -->
    <ComponentGroup Id="CoreFiles" Directory="INSTALLFOLDER">

      <Component Id="DaemonExe" Guid="A1B2C3D4-E5F6-7A8B-9C0D-E1F2A3B4C5D6">
        <File Id="VolMonDaemon" Source="$(SourceDir)\daemon\VolMon.Daemon.exe" KeyPath="yes" />
      </Component>

      <Component Id="GuiExe" Guid="B2C3D4E5-F6A7-8B9C-0D1E-F2A3B4C5D6E7">
        <File Id="VolMonGUI" Source="$(SourceDir)\gui\VolMon.GUI.exe" KeyPath="yes" />
      </Component>

      <Component Id="RegisterScript" Guid="E5F6A7B8-C9D0-1E2F-3A4B-C5D6E7F8A9B0">
        <File Id="RegisterPs1" Source="$(SourceDir)\register.ps1" KeyPath="yes" />
      </Component>

      <Component Id="IconFile" Guid="F6A7B8C9-D0E1-2F3A-4B5C-D6E7F8A9B0C1">
        <File Id="VolMonIco" Source="$(SourceDir)\volmon.ico" KeyPath="yes" />
      </Component>

    </ComponentGroup>

    <!-- ── Hardware files (optional feature) ─────────────────────── -->
    <ComponentGroup Id="HardwareFiles" Directory="INSTALLFOLDER">

      <Component Id="HardwareExe" Guid="C3D4E5F6-A7B8-9C0D-1E2F-A3B4C5D6E7F8">
        <File Id="VolMonHardware" Source="$(SourceDir)\hardware\VolMon.Hardware.exe" KeyPath="yes" />
      </Component>

      <Component Id="HardwareGuiExe" Guid="D4E5F6A7-B8C9-0D1E-2F3A-B4C5D6E7F8A9">
        <File Id="VolMonHardwareGUI" Source="$(SourceDir)\hardware-gui\VolMon.HardwareGUI.exe" KeyPath="yes" />
      </Component>

      <!-- Layout JSON files — installed to Hardware\Beacn\Mix\Layouts\ -->
      <Component Id="LayoutFiles" Guid="A7B8C9D0-E1F2-3A4B-5C6D-E7F8A9B0C1D2" Directory="LayoutsDir">
        <File Id="Layout_DefaultVertical" Source="$(SourceDir)\hardware\Hardware\Beacn\Mix\Layouts\VolMon_Layout_BeacnMix_default-vertical.json"  KeyPath="yes" />
        <File Id="Layout_HorizontalBars"  Source="$(SourceDir)\hardware\Hardware\Beacn\Mix\Layouts\VolMon_Layout_BeacnMix_horizontal-bars.json" />
        <File Id="Layout_CompactGrid"     Source="$(SourceDir)\hardware\Hardware\Beacn\Mix\Layouts\VolMon_Layout_BeacnMix_compact-grid.json" />
        <File Id="Layout_HorseshoeGauges" Source="$(SourceDir)\hardware\Hardware\Beacn\Mix\Layouts\VolMon_Layout_BeacnMix_horseshoe-gauges.json" />
      </Component>

      <!-- Bundled fonts — installed to Hardware\Beacn\Mix\Layouts\Fonts\ -->
      <Component Id="LayoutFonts" Guid="B8C9D0E1-F2A3-4B5C-6D7E-F8A9B0C1D2E3" Directory="LayoutsFontsDir">
        <File Id="Font_MontserratRegular" Source="$(SourceDir)\hardware\Hardware\Beacn\Mix\Layouts\Fonts\Montserrat-Regular.ttf" KeyPath="yes" />
        <File Id="Font_MontserratBold"    Source="$(SourceDir)\hardware\Hardware\Beacn\Mix\Layouts\Fonts\Montserrat-Bold.ttf" />
        <File Id="Font_MontserratLicense" Source="$(SourceDir)\hardware\Hardware\Beacn\Mix\Layouts\Fonts\Montserrat-OFL.txt" />
      </Component>

    </ComponentGroup>

    <!-- ── Features ──────────────────────────────────────────────── -->
    <Feature Id="CoreFeature"
             Title="VolMon"
             Description="Volume group daemon and GUI. Required."
             Level="1"
             AllowAbsent="no"
             Display="expand">
      <ComponentGroupRef Id="CoreFiles" />

      <Feature Id="HardwareFeature"
               Title="Hardware Support"
               Description="Hardware daemon and GUI for USB volume controllers (e.g. Beacn Mix). Only needed if you own a supported device."
               Level="2">
        <ComponentGroupRef Id="HardwareFiles" />
      </Feature>
    </Feature>

    <!--
      ── Post-install custom actions ──────────────────────────────────

      ExeCommand custom actions (Type 34) launch an executable directly —
      no extension DLL required. Impersonate="yes" ensures the action runs
      under the installing user's token rather than SYSTEM, which is
      required for Task Scheduler AtLogOn tasks and per-user Startup folder
      shortcuts. PowerShell is invoked with -WindowStyle Hidden so no
      console window flashes during the installer UI.

      Four actions cover the matrix of install/uninstall × with/without hardware:
        RunRegister           — core only (hardware feature not selected)
        RunRegisterHardware   — core + hardware (hardware feature selected)
        RunUnregister         — unregister core (hardware feature was not installed)
        RunUnregisterHardware — unregister core + hardware (hardware feature was installed)
    -->

    <!-- Install: core only -->
    <CustomAction
      Id="RunRegister"
      ExeCommand="powershell.exe -NonInteractive -WindowStyle Hidden -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]register.ps1&quot;"
      Directory="INSTALLFOLDER"
      Execute="deferred"
      Impersonate="yes"
      Return="ignore" />

    <!-- Install: core + hardware -->
    <CustomAction
      Id="RunRegisterHardware"
      ExeCommand="powershell.exe -NonInteractive -WindowStyle Hidden -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]register.ps1&quot; -IncludeHardware"
      Directory="INSTALLFOLDER"
      Execute="deferred"
      Impersonate="yes"
      Return="ignore" />

    <!-- Uninstall: core only -->
    <CustomAction
      Id="RunUnregister"
      ExeCommand="powershell.exe -NonInteractive -WindowStyle Hidden -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]register.ps1&quot; -Unregister"
      Directory="INSTALLFOLDER"
      Execute="deferred"
      Impersonate="yes"
      Return="ignore" />

    <!-- Uninstall: core + hardware -->
    <CustomAction
      Id="RunUnregisterHardware"
      ExeCommand="powershell.exe -NonInteractive -WindowStyle Hidden -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]register.ps1&quot; -Unregister -IncludeHardware"
      Directory="INSTALLFOLDER"
      Execute="deferred"
      Impersonate="yes"
      Return="ignore" />

    <InstallExecuteSequence>
      <!-- Register after files are installed; branch on whether hardware feature is selected -->
      <Custom Action="RunRegisterHardware" After="InstallFiles"
              Condition="NOT Installed AND &amp;HardwareFeature=3" />
      <Custom Action="RunRegister"         After="InstallFiles"
              Condition="NOT Installed AND NOT &amp;HardwareFeature=3" />

      <!-- Unregister before files are removed; branch on whether hardware feature was installed -->
      <Custom Action="RunUnregisterHardware" Before="RemoveFiles"
              Condition="Installed AND NOT UPGRADINGPRODUCTCODE AND !HardwareFeature=3" />
      <Custom Action="RunUnregister"         Before="RemoveFiles"
              Condition="Installed AND NOT UPGRADINGPRODUCTCODE AND NOT !HardwareFeature=3" />
    </InstallExecuteSequence>

  </Package>
</Wix>
