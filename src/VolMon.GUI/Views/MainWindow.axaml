<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VolMon.GUI.ViewModels"
        xmlns:conv="using:VolMon.GUI.Converters"
        x:Class="VolMon.GUI.Views.MainWindow"
        Title="VolMon - Volume Monitoring and Control"
        Icon="avares://VolMon.GUI/Assets/VolMonLogo.png"
        Width="720" Height="700"
        MinWidth="520" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="#2B2B2B">

    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>

    <DockPanel Margin="8">

        <!-- ═══ STATUS BAR (bottom, always visible) ═══ -->
        <Border DockPanel.Dock="Bottom" Margin="0,6,0,0" Padding="4,4"
                Background="#242424" CornerRadius="3">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Daemon: " Foreground="#888" FontSize="11" />
                <TextBlock Text="{Binding DaemonStatusText}"
                           Foreground="{Binding DaemonStatusColor}" FontSize="11" />
                <TextBlock Text="     " />
                <TextBlock Text="{Binding StatusSummary}" Foreground="#666" FontSize="11" />
            </StackPanel>
        </Border>

        <!-- ═══ HEADER BAR ═══ -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <TextBlock Text="VolMon" FontSize="20" FontWeight="Bold"
                       Foreground="White" VerticalAlignment="Center" />

            <!-- Settings gear button -->
            <Button DockPanel.Dock="Right" Content="&#x2699;"
                    Command="{Binding ToggleSettingsCommand}"
                    FontSize="18" Padding="6,2"
                    Background="Transparent" Foreground="#888"
                    VerticalAlignment="Center" Margin="6,0,0,0"
                    ToolTip.Tip="Shortcut Settings" />

            <Button Content="Add" Command="{Binding AddGroupCommand}"
                    DockPanel.Dock="Right" Padding="10,4" />
            <TextBox Text="{Binding NewGroupName}" Watermark="New group..."
                     DockPanel.Dock="Right" Width="140" Margin="12,0,6,0" />
        </DockPanel>

        <!-- ═══ SHORTCUT SETTINGS PANEL (collapsible) ═══ -->
        <Border DockPanel.Dock="Top"
                IsVisible="{Binding ShowSettings}"
                Background="#303030" CornerRadius="4"
                Padding="12,8" Margin="0,0,0,8"
                BorderBrush="#444" BorderThickness="1">
            <StackPanel Spacing="6">
                <TextBlock Text="SHORTCUT SETTINGS" Foreground="#AAAAAA"
                           FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4" />
                <ItemsControl ItemsSource="{Binding ShortcutBindings}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:ShortcutBindingViewModel">
                            <Grid ColumnDefinitions="120,*,Auto,Auto" Margin="0,2">
                                <TextBlock Grid.Column="0" Text="{Binding Label}"
                                           Foreground="#CCC" FontSize="12"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Classes="shortcutKey"
                                        Tag="{Binding}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Padding="6,3" MinWidth="80"
                                        Background="#444" Foreground="White"
                                        FontSize="12" FontFamily="Consolas,monospace"
                                        CornerRadius="3">
                                    <Button.Content>
                                        <TextBlock>
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0}">
                                                    <Binding Path="KeyDisplay" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Button.Content>
                                </Button>
                                <Button Grid.Column="2"
                                        Classes="shortcutClear"
                                        Tag="{Binding}"
                                        Content="&#x2715;"
                                        FontSize="10" Padding="4,2"
                                        Background="Transparent" Foreground="#888"
                                        Margin="4,0,0,0"
                                        ToolTip.Tip="Remove binding" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="Click a key button, then press the desired key to rebind."
                           Foreground="#666" FontSize="10" Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <!-- ═══ GROUP COLUMNS ═══ -->
        <Border DockPanel.Dock="Top" BorderBrush="#444" BorderThickness="0,0,0,1"
                Margin="0,0,0,4" Padding="0,0,0,8">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="6" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:GroupColumnViewModel">
                            <Border Width="160" MinHeight="360"
                                    Background="#363636" CornerRadius="4"
                                    Padding="6"
                                    Classes="groupColumn"
                                    Tag="{Binding Id}"
                                    DragDrop.AllowDrop="True">
                                <DockPanel>
                                    <!-- Group header: skip-X | drag-handle name | checkmark | ellipsis -->
                                    <DockPanel DockPanel.Dock="Top" Margin="0,2,0,2">
                                        <!-- Ellipsis menu (right) -->
                                        <Border DockPanel.Dock="Right"
                                                Classes="groupMenu"
                                                Background="Transparent"
                                                Cursor="Hand"
                                                Padding="4,2"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="&#x22EF;" Foreground="#888"
                                                       FontSize="14" FontWeight="Bold" />
                                        </Border>

                                        <!-- Default checkmark — visible only when IsDefault (right of name) -->
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="&#x2713;"
                                                   Foreground="#4CAF50"
                                                   FontSize="13" FontWeight="Bold"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,2,0"
                                                   IsVisible="{Binding IsDefault}"
                                                   ToolTip.Tip="Default group" />

                                        <!-- Compatibility Mode shield — Linux only, visible when Mode = Compatibility -->
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="&#x1F6E1;"
                                                   FontSize="10"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,2,0"
                                                   IsVisible="{Binding Mode, Converter={x:Static conv:CompatModeVisibilityConverter.Instance}}"
                                                   ToolTip.Tip="Compatibility Mode: app volume sliders have no effect" />

                                        <!-- Skip-shortcut X — visible only when SkipShortcut (left edge) -->
                                        <TextBlock DockPanel.Dock="Left"
                                                   Text="&#x274C;"
                                                   FontSize="10"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,3,0"
                                                   IsVisible="{Binding SkipShortcut}"
                                                   ToolTip.Tip="Skipped by shortcuts" />

                                        <Border Classes="groupDragHandle"
                                                Background="Transparent"
                                                Cursor="SizeAll"
                                                Padding="0,2">
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="White" FontWeight="SemiBold"
                                                       FontSize="13" HorizontalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Border>
                                    </DockPanel>

                                    <!-- Color accent bar -->
                                    <Border DockPanel.Dock="Top" Height="6"
                                            CornerRadius="2"
                                            Background="{Binding ColorBrush}"
                                            Margin="0,0,0,6"
                                            Cursor="Hand"
                                            Classes="colorBar" />

                                    <!-- Mute checkbox -->
                                    <CheckBox DockPanel.Dock="Bottom"
                                              Content="Muted" IsChecked="{Binding Muted}"
                                              Foreground="#AAAAAA" FontSize="11"
                                              HorizontalAlignment="Center"
                                              Margin="0,4,0,0" />

                                    <!-- Members list — FIXED height scrollable -->
                                    <Border DockPanel.Dock="Bottom"
                                            Background="#2E2E2E" CornerRadius="3"
                                            BorderBrush="#444" BorderThickness="1"
                                            Margin="0,6,0,0" Padding="2"
                                            Height="100">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled">
                                            <ItemsControl ItemsSource="{Binding Members}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="vm:GroupMemberViewModel">
                                                        <Border Background="#444" CornerRadius="2"
                                                                Padding="4,2" Margin="0,1"
                                                                Classes="draggableMember"
                                                                Tag="{Binding}">
                                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <TextBlock Text="&#x2298;" FontSize="9"
                                                                           IsVisible="{Binding ShowDisconnected}"
                                                                           Foreground="#666"
                                                                           VerticalAlignment="Center" />
                                                                <TextBlock Text="{Binding DisplayName}"
                                                                           Foreground="{Binding TextBrush}"
                                                                           FontSize="11"
                                                                           TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>

                                    <!-- Volume slider — centered, fills remaining space -->
                                    <DockPanel Margin="0,4">
                                        <TextBlock DockPanel.Dock="Bottom"
                                                   Text="{Binding VolumeText}"
                                                   Foreground="#AAAAAA" FontSize="11"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,2,0,0" />
                                        <Slider Orientation="Vertical" Minimum="0" Maximum="100"
                                                Value="{Binding Volume}"
                                                TickFrequency="1" IsSnapToTickEnabled="True"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Stretch"
                                                MinHeight="80"
                                                DragDrop.AllowDrop="False" />
                                    </DockPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ═══ BOTTOM POOLS (fills remaining, scrolls if needed) ═══ -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid ColumnDefinitions="*,*,*" MinHeight="100">
                <!-- Recording Devices -->
                <DockPanel Grid.Column="0" Margin="0,0,4,0">
                    <TextBlock DockPanel.Dock="Top" Text="RECORDING DEVICES"
                               Foreground="#FF9500" FontWeight="SemiBold" FontSize="11"
                               Margin="0,4,0,4" />
                    <Border Background="#333" CornerRadius="4" Padding="4"
                            MinHeight="60"
                            Classes="poolArea" Tag="input-device"
                            DragDrop.AllowDrop="True">
                        <ItemsControl ItemsSource="{Binding UnassignedInputs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:PoolItemViewModel">
                                    <Border Background="#444" CornerRadius="2"
                                            Padding="4,2" Margin="0,1"
                                            Classes="draggablePool"
                                            Tag="{Binding}">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="#CCCCCC" FontSize="11"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </DockPanel>

                <!-- Playback Devices -->
                <DockPanel Grid.Column="1" Margin="2,0,2,0">
                    <TextBlock DockPanel.Dock="Top" Text="PLAYBACK DEVICES"
                               Foreground="#00B4D8" FontWeight="SemiBold" FontSize="11"
                               Margin="0,4,0,4" />
                    <Border Background="#333" CornerRadius="4" Padding="4"
                            MinHeight="60"
                            Classes="poolArea" Tag="output-device"
                            DragDrop.AllowDrop="True">
                        <ItemsControl ItemsSource="{Binding UnassignedOutputs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:PoolItemViewModel">
                                    <Border Background="#444" CornerRadius="2"
                                            Padding="4,2" Margin="0,1"
                                            Classes="draggablePool"
                                            Tag="{Binding}">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="#CCCCCC" FontSize="11"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </DockPanel>

                <!-- Applications -->
                <DockPanel Grid.Column="2" Margin="4,0,0,0">
                    <TextBlock DockPanel.Dock="Top" Text="APPLICATIONS"
                               Foreground="#2EC4B6" FontWeight="SemiBold" FontSize="11"
                               Margin="0,4,0,4" />
                    <Border Background="#333" CornerRadius="4" Padding="4"
                            MinHeight="60"
                            Classes="poolArea" Tag="program"
                            DragDrop.AllowDrop="True">
                        <ItemsControl ItemsSource="{Binding UnassignedPrograms}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:PoolItemViewModel">
                                    <Border Background="#444" CornerRadius="2"
                                            Padding="4,2" Margin="0,1"
                                            Classes="draggablePool"
                                            Tag="{Binding}">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <!-- Ignored indicator: ⊗ (blocked) -->
                                            <TextBlock Text="&#x2297;" FontSize="9"
                                                       IsVisible="{Binding IsIgnored}"
                                                       Foreground="#888"
                                                       VerticalAlignment="Center"
                                                       ToolTip.Tip="Ignored" />
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Foreground="#CCCCCC" FontSize="11"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </DockPanel>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
