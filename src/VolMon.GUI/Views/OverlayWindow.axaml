<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="VolMon.GUI.Views.OverlayWindow"
        Title="VolMon Overlay"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        CanResize="False"
        ShowInTaskbar="False"
        Topmost="True"
        Width="280" Height="80"
        WindowStartupLocation="Manual"
        Focusable="False"
        IsHitTestVisible="False">

    <Border Background="#CC1E1E1E" CornerRadius="10" Padding="16,10"
            Width="260"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            BorderBrush="#55FFFFFF" BorderThickness="1">
        <StackPanel Spacing="6" Width="228">
            <!-- Group name + muted indicator -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                <TextBlock x:Name="GroupNameText"
                           Text="Group"
                           Foreground="White"
                           FontSize="14" FontWeight="SemiBold" />
                <TextBlock x:Name="MutedIndicator"
                           Text="MUTED"
                           Foreground="#E63946"
                           FontSize="11" FontWeight="Bold"
                           VerticalAlignment="Center"
                           IsVisible="False" />
            </StackPanel>

            <!-- Volume bar (fixed width) -->
            <Grid Height="8" Width="228" ClipToBounds="True">
                <Border Background="#44FFFFFF" CornerRadius="4" />
                <Border x:Name="VolumeFill"
                        Background="#4A90D9" CornerRadius="4"
                        HorizontalAlignment="Left"
                        Width="228" />
            </Grid>

            <!-- Volume text -->
            <TextBlock x:Name="VolumeText"
                       Text="100%"
                       Foreground="#CCCCCC"
                       FontSize="11"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Border>
</Window>
