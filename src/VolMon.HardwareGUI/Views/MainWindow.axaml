<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VolMon.HardwareGUI.ViewModels"
        x:Class="VolMon.HardwareGUI.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="VolMon Hardware Manager"
        Icon="avares://VolMon.HardwareGUI/Assets/VolMonLogo.png"
        Width="700" Height="600"
        MinWidth="500" MinHeight="400">

  <Grid RowDefinitions="Auto,*,Auto" Margin="16">

    <!-- Header: Logo + Daemon controls -->
    <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,16">
      <StackPanel Orientation="Horizontal" Spacing="12">
        <Image Source="avares://VolMon.HardwareGUI/Assets/VolMonLogo.png"
               Width="32" Height="32" VerticalAlignment="Center" />
        <TextBlock Text="VolMon Hardware Manager" FontSize="20" FontWeight="Bold"
                   VerticalAlignment="Center" />
      </StackPanel>

      <TextBlock Text="{Binding StatusText}" Foreground="#AAA" />

      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Content="Refresh" Command="{Binding RefreshCommand}" />
        <Button Content="{Binding DaemonButtonText}" Command="{Binding ToggleDaemonCommand}" />
        <Button Content="{Binding ServiceButtonText}" Command="{Binding ToggleServiceCommand}" />
      </StackPanel>
    </StackPanel>

    <!-- Main content: Device list + config panel -->
    <Grid Grid.Row="1" ColumnDefinitions="220,*">

      <!-- Device list -->
      <Border Grid.Column="0" BorderBrush="#444" BorderThickness="0,0,1,0" Padding="0,0,8,0">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Text="Devices" FontWeight="Bold" FontSize="14"
                     Margin="0,0,0,8" />
          <ListBox ItemsSource="{Binding Devices}"
                   SelectedItem="{Binding SelectedDevice}"
                   SelectionMode="Single">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:DeviceViewModel">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <CheckBox IsChecked="{Binding Enabled}" VerticalAlignment="Center" />
                  <StackPanel Spacing="2">
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding DeviceId}" FontSize="11" Foreground="#888" />
                  </StackPanel>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>

      <!-- Device config panel -->
      <ScrollViewer Grid.Column="1" Padding="16,0,0,0">
        <ContentControl Content="{Binding SelectedDevice}">
          <ContentControl.ContentTemplate>
            <DataTemplate DataType="vm:DeviceViewModel">
              <StackPanel Spacing="12">
                <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold" />
                <TextBlock Text="{Binding DeviceId}" Foreground="#888" />

                <Separator />

                <!-- Display settings (only for devices with displays) -->
                <StackPanel Spacing="8" IsVisible="{Binding HasDisplay}">

                  <!-- Loading state -->
                  <TextBlock Text="Loading device configuration..."
                             IsVisible="{Binding !HasDeviceConfig}"
                             Foreground="#888" FontStyle="Italic" />

                  <!-- Loaded config -->
                  <StackPanel Spacing="8" IsVisible="{Binding HasDeviceConfig}">
                    <TextBlock Text="Display Settings" FontWeight="Bold" FontSize="14" />

                    <!-- Layout -->
                    <StackPanel Spacing="4">
                      <TextBlock Text="Layout" />
                      <ComboBox ItemsSource="{Binding AvailableLayouts}"
                                SelectedItem="{Binding Layout, Mode=TwoWay}"
                                HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <!-- Display Brightness -->
                    <StackPanel Spacing="4">
                      <TextBlock>
                        <Run Text="Display Brightness: " />
                        <Run Text="{Binding DisplayBrightness}" />
                        <Run Text="%" />
                      </TextBlock>
                      <Slider Minimum="0" Maximum="100" Value="{Binding DisplayBrightness}"
                              TickFrequency="1" IsSnapToTickEnabled="True" />
                    </StackPanel>

                    <!-- Dim Brightness -->
                    <StackPanel Spacing="4">
                      <TextBlock>
                        <Run Text="Dim Brightness: " />
                        <Run Text="{Binding DimBrightness}" />
                        <Run Text="%" />
                      </TextBlock>
                      <Slider Minimum="0" Maximum="100" Value="{Binding DimBrightness}"
                              TickFrequency="1" IsSnapToTickEnabled="True" />
                    </StackPanel>

                    <!-- Dim Timeout -->
                    <StackPanel Spacing="4">
                      <TextBlock>
                        <Run Text="Dim After: " />
                        <Run Text="{Binding DimTimeoutSeconds}" />
                        <Run Text="s" />
                      </TextBlock>
                      <Slider Minimum="5" Maximum="300" Value="{Binding DimTimeoutSeconds}"
                              TickFrequency="5" IsSnapToTickEnabled="True" />
                    </StackPanel>

                    <!-- Off Timeout -->
                    <StackPanel Spacing="4">
                      <TextBlock>
                        <Run Text="Display Off After: " />
                        <Run Text="{Binding OffTimeoutSeconds}" />
                        <Run Text="s" />
                      </TextBlock>
                      <Slider Minimum="10" Maximum="600" Value="{Binding OffTimeoutSeconds}"
                              TickFrequency="5" IsSnapToTickEnabled="True" />
                    </StackPanel>

                    <Separator />

                    <TextBlock Text="Control Settings" FontWeight="Bold" FontSize="14" />

                    <!-- Volume Step -->
                    <StackPanel Spacing="4">
                      <TextBlock>
                        <Run Text="Volume Step Per Tick: " />
                        <Run Text="{Binding VolumeStepPerDelta}" />
                        <Run Text="%" />
                      </TextBlock>
                      <Slider Minimum="1" Maximum="10" Value="{Binding VolumeStepPerDelta}"
                              TickFrequency="1" IsSnapToTickEnabled="True" />
                    </StackPanel>
                  </StackPanel>
                </StackPanel>

                <!-- No display support -->
                <TextBlock Text="This device does not have configurable display settings."
                           IsVisible="{Binding !HasDisplay}"
                           Foreground="#888" FontStyle="Italic" />
              </StackPanel>
            </DataTemplate>
          </ContentControl.ContentTemplate>
        </ContentControl>
      </ScrollViewer>

    </Grid>

    <!-- Footer -->
    <TextBlock Grid.Row="2" Text="Changes are applied instantly via file watchers"
               Foreground="#666" FontSize="11" Margin="0,8,0,0" />

  </Grid>
</Window>
